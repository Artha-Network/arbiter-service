# Arbiter Service Environment Variables
# Copy to .env and fill in values

# Required. Anthropic API key for Claude-based arbitration and contract generation
ANTHROPIC_API_KEY=

# Required. Ed25519 secret key (hex) for signing resolve tickets
ARBITER_ED25519_SECRET_HEX=

# Optional. Claude model for arbitration (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional. Claude model for contract generation (default: claude-sonnet-4-6)
ANTHROPIC_CONTRACT_MODEL=claude-sonnet-4-6

# Optional. Admin API key for authenticating requests (required in production)
ARBITER_ADMIN_KEY=

# Optional. Port (default: 3001)
PORT=3001

# Optional. Node environment
NODE_ENV=development
